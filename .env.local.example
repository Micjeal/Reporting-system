# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Application URL (for email redirects and OAuth callbacks)
# Local development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production example: NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Optional: Ngrok URL for local development (update when ngrok URL changes)
NEXT_PUBLIC_NGROK_URL=your_ngrok_url_here

# Database
DATABASE_URL=your_database_url_here
